# ────────────────────────────────────────────────
# GateIn AI — environment variables
# Copy this file to .env.local for local dev.
# Set the same values in Vercel → Project Settings → Environment Variables for prod.
# ────────────────────────────────────────────────

# Contact form → Formspree. Server-side only; keep unprefixed.
# Get the form ID from https://formspree.io → the form's endpoint URL (https://formspree.io/f/<FORM_ID>).
# If this is unset, the /api/contact route will log a warning and drop the submission.
FORMSPREE_FORM_ID=

# PostHog — product analytics. These are the *public* project keys; safe to ship to the client.
# Find them at https://app.posthog.com → Project Settings → Project API Key.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
